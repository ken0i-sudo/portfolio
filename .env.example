# Public site URL - used for canonical URLs, sitemap, OG tags and JSON-LD
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Formspree endpoint for the contact form (https://formspree.io)
# Create a free form and paste the endpoint ID below
NEXT_PUBLIC_FORMSPREE_ID=https://formspree.io/f/mwvdgreb

# Optional: Google Site Verification token (Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Analytics (e.g. Plausible, GA4 measurement id)
NEXT_PUBLIC_GA_ID=
